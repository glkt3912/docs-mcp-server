# 動作モード
# true: ローカルの docs/ フォルダを参照 / false: GitHub リポジトリを参照
LOCAL_MODE=false

# GitHub モード設定（LOCAL_MODE=false の場合に必須）
GITHUB_TOKEN=ghp_YOUR_TOKEN_HERE
GITHUB_OWNER=your-org
GITHUB_REPO=your-repo
GITHUB_BRANCH=main

# ローカルモード設定（LOCAL_MODE=true の場合に使用）
DOCS_BASE_PATH=./docs

# GitHub API 失敗時にローカルへフォールバックする（任意）
FALLBACK_TO_LOCAL=false
